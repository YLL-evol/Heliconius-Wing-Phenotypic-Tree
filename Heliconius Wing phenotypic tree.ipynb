    "def extract_model_features(images):\n",
    "\n",
    "    feats = []\n",
    "\n",
    "    for img in images:\n",
    "\n",
    "        if img.ndim != 2:\n",
    "            continue\n",
    "\n",
    "        feats.append([\n",
    "            *fourier_features(img),\n",
    "            fractal_dimension(img),\n",
    "            autocorr(img)\n",
    "        ])\n",
    "\n",
    "    return np.array(feats)"
   ]
