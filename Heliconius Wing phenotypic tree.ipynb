   "cell_type": "markdown",
   "id": "b38b79b2-6f3b-47b8-8be1-0507aa9a1455",
   "metadata": {},
   "source": [
    "### Perlin noise model\n",
    "Perlin noise generates texture-like patterns similar to irregular pigmentation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 92,
   "id": "dde2272d-7bd6-47ec-99bf-d40a2d5a0c86",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "def perlin(size=256, scale=10, octaves=4, persistence=0.5):\n",
    "\n",
    "    def f(x,y):\n",
    "        return np.sin(x)+np.cos(y)\n",
    "\n",
    "    noise = np.zeros((size,size))\n",
    "\n",
    "    freq = scale\n",
    "    amp = 1\n",
    "\n",
    "    for _ in range(octaves):\n",
    "\n",
    "        x = np.linspace(0,freq,size)\n",
    "        y = np.linspace(0,freq,size)\n",
    "\n",
    "        xv,yv = np.meshgrid(x,y)\n",
    "\n",
    "        noise += amp * f(xv,yv)\n",
    "\n",
    "        freq *= 2\n",
    "        amp *= persistence\n",
    "\n",
    "    noise = (noise - noise.min())/(noise.max()-noise.min())\n",
    "\n",
    "    return noise"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f70500cb-bb24-4c30-8620-d7830b9b804a",
   "metadata": {},
   "source": [
    "Generate library"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 93,
   "id": "c46061db-bb51-4bb6-963f-f53b4f3297c5",
   "metadata": {},
   "outputs": [],
   "source": [
    "perlin_params = []\n",
    "\n",
    "for scale in [3,5,10,15]:\n",
    "    for octaves in [2,3,4]:\n",
    "        for persistence in [0.3,0.5,0.7]:\n",
    "\n",
    "            perlin_params.append((scale,octaves,persistence))\n",
    "\n",
    "perlin_library = [\n",
    "    perlin(scale=s,octaves=o,persistence=p)\n",
    "    for s,o,p in perlin_params\n",
    "]"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "27a1bdbd-d8dc-4087-80cb-7f7f36f7450f",
   "metadata": {},
   "source": [
    "### Cellular automata model\n",
    "This produces patch / mosaic patterns."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 94,
   "id": "e2cf2550-15ad-48d2-b66d-e0677b06a479",
   "metadata": {},
   "outputs": [],
   "source": [
    "def cellular_automata(size=256, steps=50, p=0.5):\n",
    "\n",
    "    grid = np.random.rand(size,size) > p\n",
    "\n",
    "    for _ in range(steps):\n",
    "\n",
    "        neighbors = (\n",
    "            np.roll(grid,1,0)+np.roll(grid,-1,0)+\n",
    "            np.roll(grid,1,1)+np.roll(grid,-1,1)+\n",
    "            np.roll(np.roll(grid,1,0),1,1)+\n",
    "            np.roll(np.roll(grid,1,0),-1,1)+\n",
    "            np.roll(np.roll(grid,-1,0),1,1)+\n",
    "            np.roll(np.roll(grid,-1,0),-1,1)\n",
    "        )\n",
    "\n",
    "        grid = (neighbors > 4)\n",
    "\n",
    "    return grid.astype(float)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "86a901fc-ce54-4a94-abf4-bb307ceb4deb",
   "metadata": {},
   "source": [
    "Generate library:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 95,
   "id": "13af6ff2-d2f9-435b-8e8f-8b119bbbee46",
   "metadata": {},
   "outputs": [],
   "source": [
    "ca_params = []\n",
    "\n",
    "for p in [0.3,0.4,0.5,0.6]:\n",
    "    for steps in [20,40,60]:\n",
    "\n",
    "        ca_params.append((p,steps))\n",
    "\n",
    "ca_library = [\n",
    "    cellular_automata(p=p,steps=s)\n",
    "    for p,s in ca_params\n",
    "]"
   ]
  },
