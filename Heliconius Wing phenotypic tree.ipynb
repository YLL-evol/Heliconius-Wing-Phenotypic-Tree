    "def bootstrap_tree(X, n=100):\n",
    "\n",
    "    trees = []\n",
    "\n",
    "    for _ in range(n):\n",
    "\n",
    "        idx = np.random.choice(\n",
    "            X.shape[1],\n",
    "            X.shape[1],\n",
    "            replace=True\n",
    "        )\n",
    "\n",
    "        Xb = X[:, idx]\n",
    "\n",
    "        d = squareform(pdist(Xb))\n",
    "\n",
    "        matrix = DistanceMatrix(species, d.tolist())\n",
    "        tree = constructor.nj(matrix)\n",
    "\n",
    "        trees.append(tree)\n",
    "\n",
    "    return trees\n",
    "\n",
    "trees = bootstrap_tree(X)"
   ]
