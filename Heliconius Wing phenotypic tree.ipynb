   "source": [
    "## 3rd correction \n",
    "\n",
    "rd_params = []\n",
    "rd_library = []\n",
    "\n",
    "for F in np.linspace(0.01,0.06,8):\n",
    "    for k in np.linspace(0.04,0.07,8):\n",
    "\n",
    "        rd_params.append((F,k))\n",
    "\n",
    "        img = gray_scott(F=F, k=k)\n",
    "\n",
    "        rd_library.append(img)"
   ]
  },
