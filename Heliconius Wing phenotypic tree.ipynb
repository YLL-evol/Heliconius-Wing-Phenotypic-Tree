   "source": [
    "## 8. Generative models\n",
    "### Reaction diffusion"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 86,
   "id": "5e1c2159-5559-426e-859b-5f4072376aab",
   "metadata": {},
   "outputs": [],
   "source": [
    "def gray_scott(size=256, steps=1000, F=0.035, k=0.065):\n",
    "\n",
    "    U = np.ones((size,size))\n",
    "    V = np.zeros((size,size))\n",
    "\n",
    "    r = 20\n",
    "\n",
    "    U[128-r:128+r,128-r:128+r] = 0.50\n",
    "    V[128-r:128+r,128-r:128+r] = 0.25\n",
    "\n",
    "    Du, Dv = 0.16, 0.08\n",
    "\n",
    "    for _ in range(steps):\n",
    "\n",
    "        Lu = (\n",
    "            np.roll(U,1,0)+np.roll(U,-1,0)+\n",
    "            np.roll(U,1,1)+np.roll(U,-1,1)-4*U)\n",
    "\n",
    "        Lv = (\n",
    "            np.roll(V,1,0)+np.roll(V,-1,0)+\n",
    "            np.roll(V,1,1)+np.roll(V,-1,1)-4*V)\n",
    "\n",
    "        UVV = U*V*V\n",
    "\n",
    "        U += Du*Lu - UVV + F*(1-U)\n",
    "        V += Dv*Lv + UVV - (F+k)*V\n",
    "\n",
    "    return V"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 87,
   "id": "b13e7a7e-2b5b-4056-8342-6b740bda36f1",
   "metadata": {},
   "outputs": [],
   "source": [
    "def rd_features(F,k):\n",
    "\n",
    "    sim = gray_scott(F=F,k=k)\n",
    "\n",
    "    return fourier_features(sim)"
   ]
  },
