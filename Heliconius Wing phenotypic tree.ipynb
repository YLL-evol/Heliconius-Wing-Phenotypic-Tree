   "metadata": {},
   "source": [
    "## 7. Spatial Statistics\n",
    "\n",
    "### Fourier spectrum"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 75,
   "id": "8726cf27-d608-4e03-a45c-27bf7fa9b003",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fourier_features(img):\n",
    "    f = np.abs(fftpack.fftshift(fftpack.fft2(img)))\n",
    "    return f.mean(), f.std()\n",
    "\n",
    "fourier = np.array([fourier_features(i) for i in gray])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "114a0da8-74c9-497a-9892-078124f2abc7",
   "metadata": {},
   "source": [
    "### Wavelet spectrum\n",
    "\n",
    "Wavelets infer:\n",
    "\n",
    "local stripe scale\n",
    "edge sharpness\n",
    "multi-scale pattern\n",
    "spot vs stripe hierarchy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 76,
   "id": "70f41f19-af68-4e5c-a9f3-7064d76b073b",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pywt\n",
    "\n",
    "def wavelet_features(img):\n",
    "\n",
    "    coeffs2 = pywt.dwt2(img, 'haar')\n",
    "\n",
    "    LL, (LH, HL, HH) = coeffs2\n",
    "\n",
    "    return [\n",
    "        LL.mean(),\n",
    "        LH.mean(),\n",
    "        HL.mean(),\n",
    "        HH.mean()\n",
    "    ]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "id": "f909a5ee-748e-4085-ab22-20872091d11e",
   "metadata": {},
   "outputs": [],
   "source": [
    "wavelet = np.array([wavelet_features(i) for i in gray])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3cef919d-36cb-4639-8cb9-f1f65e96af6b",
   "metadata": {},
   "source": [
    "### Autocorrelation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 79,
   "id": "bc1e0fd9-29a4-4f73-9f01-b8f8d3547f03",
   "metadata": {},
   "outputs": [],
   "source": [
    "def autocorr(img):\n",
    "    f = fftpack.fft2(img)\n",
    "    ac = fftpack.ifft2(f*np.conj(f)).real\n",
    "    return ac.mean()\n",
    "\n",
    "auto = np.array([autocorr(i) for i in gray])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "61595d0e-4287-4835-91d5-55a2bc390746",
   "metadata": {},
   "source": [
    "### Fractal dimension"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 80,
   "id": "093463b0-ed1c-446b-b740-fdd57f2fa39a",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fractal_dimension(Z):\n",
    "    Z = Z < filters.threshold_otsu(Z)\n",
    "    def boxcount(Z, k):\n",
    "        S = np.add.reduceat(\n",
    "            np.add.reduceat(Z, np.arange(0, Z.shape[0], k), axis=0),\n",
    "                               np.arange(0, Z.shape[1], k), axis=1)\n",
    "        return len(np.where((S > 0) & (S < k*k))[0])\n",
    "\n",
    "    sizes = 2**np.arange(2, 8)\n",
    "    counts = [boxcount(Z, s) for s in sizes]\n",
    "    coeffs = np.polyfit(np.log(sizes), np.log(counts), 1)\n",
    "    return -coeffs[0]\n",
    "\n",
    "fractal = np.array([fractal_dimension(i) for i in gray])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b49770d6-e93d-4dfa-aaa6-a7d01bc9ebc8",
   "metadata": {},
   "source": [
    "### Feature Matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 81,
   "id": "eb7827ae-4f3e-4945-8b5d-4c68cb677aff",
   "metadata": {},
   "outputs": [],
   "source": [
    "features = np.column_stack([\n",
    "    fourier[:,0],\n",
    "    fourier[:,1],\n",
    "    auto,\n",
    "    fractal,\n",
    "    wavelet\n",
    "])"
   ]
