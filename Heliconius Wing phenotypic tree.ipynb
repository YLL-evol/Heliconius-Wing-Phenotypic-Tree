   "source": [
    "### 3.2 Landmark extraction\n",
    "Automatically detect:\n",
    "\n",
    "wing contour\n",
    "tip\n",
    "base\n",
    "left/right edges"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 21,
   "id": "2609a4fe-2120-4b04-818d-0daf18362d7d",
   "metadata": {},
   "outputs": [],
   "source": [
    "from skimage.measure import find_contours\n",
    "from skimage.transform import SimilarityTransform, warp\n",
    "\n",
    "def extract_landmarks(img):\n",
    "\n",
    "    gray = color.rgb2gray(img)\n",
    "\n",
    "    mask = gray < filters.threshold_otsu(gray)\n",
    "\n",
    "    contours = find_contours(mask, 0.5)\n",
    "    contour = max(contours, key=len)\n",
    "\n",
    "    # sample evenly spaced points\n",
    "    idx = np.linspace(0, len(contour)-1, 50).astype(int)\n",
    "    landmarks = contour[idx]\n",
    "\n",
    "    return landmarks"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "10c9ef50-9086-4176-9384-89318da05621",
   "metadata": {},
   "source": [
    "### 3.3 — Procrustes alignment"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 65,
   "id": "3c6979d7-3578-4cc7-91c8-24f38836c5b3",
   "metadata": {},
   "outputs": [],
   "source": [
    "from scipy.spatial import procrustes\n",
    "\n",
    "landmarks = [extract_landmarks(i) for i in images]\n",
    "\n",
    "reference = landmarks[0]\n",
    "\n",
    "aligned_images = []\n",
    "\n",
    "for img, lm in zip(images, landmarks):\n",
    "\n",
    "    mtx1, mtx2, disparity = procrustes(reference, lm)\n",
    "\n",
    "    tform = SimilarityTransform()\n",
    "    tform.from_estimate(lm, reference)  # originally: tform.estimate  \n",
    "\n",
    "   # aligned = warp(img, tform.inverse)\n",
    "\n",
    "    aligned = warp(\n",
    "        img,\n",
    "        tform.inverse,\n",
    "        mode=\"constant\",\n",
    "        cval=0\n",
    "    )\n",
    "    \n",
    "    aligned_images.append(aligned)\n",
    "\n",
    "aligned_images = np.array(aligned_images, dtype=\"object\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 67,
   "id": "47a51fff-f471-4e7f-a497-a9b7d46d600d",
   "metadata": {},
   "outputs": [],
   "source": [
    "aligned_images = np.array(aligned_images)\n",
    "\n",
    "# replace NaN with 0\n",
    "aligned_images = np.nan_to_num(aligned_images)\n",
    "\n",
    "# create mask\n",
    "# mask = np.mean(aligned_images, axis=0) > 0"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "fe707e50-e230-4b58-8d13-c4d4534b6799",
   "metadata": {},
   "source": [
